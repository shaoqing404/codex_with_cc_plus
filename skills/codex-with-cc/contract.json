{
  "schemaVersion": 1,
  "invocationContract": "codex_with_cc_workflow",
  "artifactSchemaVersion": 3,
  "childThread": {
    "markerName": "CODEX_CLAUDE_CHILD_THREAD",
    "markerValue": "1"
  },
  "spawn": {
    "model": "gpt-5.4-mini",
    "reasoningEffort": "medium",
    "forkContext": false
  },
  "taskValidation": {
    "runnerType": "local_static",
    "entrypointPattern": "validate_delegate_task(?:\\.(?:ps1|sh|cmd|bat))?",
    "modelCalls": false,
    "consumesModelTokens": false,
    "hardGate": true
  },
  "taskFileAssist": {
    "runnerType": "openai_compatible_report",
    "defaultModel": "deepseek-v4-flash",
    "mayOverrideValidator": false,
    "mayOverrideVerifier": false,
    "canEditBusinessFiles": false,
    "canRunShellTests": false,
    "canDispatchWorkerRuns": false,
    "canAcceptWorkflowResults": false,
    "requiresLocalValidationAfterAssist": true
  },
  "dsAdvisoryBoundary": {
    "runnerType": "openai_compatible_report",
    "advisoryOnly": true,
    "mayOverrideValidator": false,
    "mayOverrideVerifier": false,
    "canEditBusinessFiles": false,
    "canRunShellTests": false,
    "canDispatchWorkerRuns": false,
    "canAcceptWorkflowResults": false,
    "artifactFields": [
      "advisoryBoundary",
      "reportOnly",
      "mayOverrideValidator",
      "mayOverrideVerifier",
      "canEditBusinessFiles",
      "canRunShellTests",
      "canDispatchWorkerRuns",
      "canAcceptWorkflowResults"
    ],
    "reportLines": [
      "advisoryOnly=true",
      "mayOverrideValidator=false",
      "mayOverrideVerifier=false",
      "canEditBusinessFiles=false",
      "canRunShellTests=false",
      "canDispatchWorkerRuns=false",
      "canAcceptWorkflowResults=false"
    ]
  },
  "orchestrationRoles": {
    "dispatch-planner": {
      "runnerType": "openai_compatible_report",
      "defaultModel": "deepseek-v4-pro",
      "mayOverrideValidator": false,
      "mayOverrideVerifier": false,
      "canEditBusinessFiles": false,
      "canRunShellTests": false,
      "purpose": "Turn user intent and tracked specs into dispatchable workflow plans and TaskFile drafts."
    },
    "run-supervisor": {
      "runnerType": "codex_child_thread",
      "defaultModel": "gpt-5.4-mini",
      "mayOverrideValidator": false,
      "mayOverrideVerifier": false,
      "canEditBusinessFiles": false,
      "canRunShellTests": true,
      "purpose": "Own one delegated run lifecycle, observe that run's artifacts, run deterministic verification, and report concise status to the Codex main thread."
    },
    "report-worker": {
      "runnerType": "openai_compatible_report",
      "defaultModel": "deepseek-v4-flash",
      "mayOverrideValidator": false,
      "mayOverrideVerifier": false,
      "canEditBusinessFiles": false,
      "canRunShellTests": false,
      "purpose": "Cheap report-only preflight, normalization, audit summaries, and routine workflow judgment."
    },
    "forensic-analyst": {
      "runnerType": "openai_compatible_report",
      "defaultModel": "deepseek-v4-pro",
      "mayOverrideValidator": false,
      "mayOverrideVerifier": false,
      "canEditBusinessFiles": false,
      "canRunShellTests": false,
      "purpose": "Explain deterministic verifier failures, classify risk, and recommend next steps without changing verifier outcomes."
    }
  },
  "workflowStateMachine": [
    "INTAKE",
    "SPEC_DRAFTED",
    "TASKFILES_DRAFTED",
    "TASKFILES_VALIDATED",
    "DISPATCH_READY",
    "RUN_SUPERVISED",
    "REPORT_READY",
    "DETERMINISTIC_VERIFIED",
    "MAIN_ACCEPTED"
  ],
  "workflowFailureStates": [
    "TASKFILE_INVALID",
    "RUN_STALE",
    "DETERMINISTIC_VERIFY_FAILED",
    "HUMAN_OVERRIDE_REQUIRED"
  ],
  "childThreadReturnProtocol": {
    "requiredFields": [
      "DelegateStatus",
      "RunId",
      "WorkflowId",
      "TaskId",
      "ArtifactRoot",
      "StatusPath",
      "ReportPath",
      "TracePath",
      "RawStreamPath",
      "ObservedState",
      "Verifier",
      "Supervisor",
      "MainThreadAction"
    ],
    "delegateStatusValues": [
      "READY",
      "DISPATCHED",
      "WAITING",
      "REPORT_READY",
      "TERMINAL",
      "REFUSED",
      "FAILED"
    ],
    "waitingStates": [
      "STARTING",
      "RUNNING_ACTIVE",
      "RUNNING_QUIET"
    ],
    "terminalStates": [
      "RUN_VERIFIED",
      "REPORT_READY",
      "FAILED",
      "STALE",
      "RUNNING_DEAD_PROCESS"
    ],
    "mainThreadActions": {
      "READY": "dispatch worker through delegate_to_claude after TaskFile validation",
      "REFUSED": "do not call delegate_to_claude; run ccstatus claude --json or repair Claude Code runtime",
      "STARTING": "run ccsupervise -RunId <run-id> -ArtifactRoot <artifact-root> -Wait",
      "RUNNING_ACTIVE": "run ccsupervise -RunId <run-id> -ArtifactRoot <artifact-root> -Wait",
      "RUNNING_QUIET": "run ccsupervise -RunId <run-id> -ArtifactRoot <artifact-root> -Wait",
      "RUN_VERIFIED": "run verify_delegate_run then review report evidence",
      "REPORT_READY": "run verify_delegate_run then review report evidence",
      "FAILED": "inspect status, trace, stream, and decide rerun or forensics",
      "STALE": "treat as interrupted then rerun or trigger forensics",
      "RUNNING_DEAD_PROCESS": "treat as interrupted then rerun or trigger forensics"
    },
    "completionRule": "Printed artifact paths, status=running, STARTING, RUNNING_ACTIVE, RUNNING_QUIET, READY, and REFUSED are not worker completion. REFUSED is a terminal framework precondition failure with acceptanceAllowed=false; it must be reported back to the main thread instead of retried blindly."
  },
  "mainThreadHandoffSchema": {
    "requiredFields": [
      "delegateStatus",
      "observedState",
      "acceptanceAllowed",
      "mainThreadAction",
      "recommendedWaitSeconds",
      "nextCommand",
      "confidence",
      "failureLayer",
      "humanInterventionRequired",
      "evidencePaths",
      "mayOverrideValidator",
      "mayOverrideVerifier"
    ],
    "acceptanceRule": "acceptanceAllowed=true is required before the main thread can present delegated work as accepted. Worker claims, DS reports, and dashboard records cannot override deterministic verifiers.",
    "recommendedWaitPolicy": {
      "STARTING": 60,
      "RUNNING_ACTIVE": 60,
      "RUNNING_QUIET": 300,
      "RUNNING_DEAD_PROCESS": 0,
      "STALE": 0
    }
  },
  "runHandoffArtifactSchema": {
    "artifactPattern": "handoff_<RunId>.json",
    "markdownPattern": "handoff_<RunId>.md",
    "command": "ccstatus run -RunId <run-id> -ArtifactRoot <artifact-root> --json",
    "requiredFields": [
      "handoffArtifactType",
      "runId",
      "overall",
      "acceptanceAllowed",
      "summary",
      "handoff",
      "handoffPath",
      "handoffMarkdownPath",
      "mayOverrideValidator",
      "mayOverrideVerifier"
    ],
    "handoffRequiredFields": [
      "delegateStatus",
      "observedState",
      "acceptanceAllowed",
      "mainThreadAction",
      "recommendedWaitSeconds",
      "nextCommand",
      "confidence",
      "evidencePaths",
      "childThreadResponseTemplate",
      "mayOverrideValidator",
      "mayOverrideVerifier"
    ],
    "acceptanceRule": "Run handoff artifacts are transfer evidence for the Codex main thread and child thread. They cannot replace run audits, workflow audits, deterministic verifiers, review gates, or final acceptance."
  },
  "runtimeProviderSchema": {
    "ccswitchProvider": {
      "cliNames": [
        "ccwitch",
        "ccswitch",
        "cc-switch"
      ],
      "knownStateKinds": [
        "home_state",
        "desktop_app_support",
        "desktop_preferences"
      ],
      "requiredFields": [
        "provider",
        "available",
        "path",
        "cliCandidates",
        "desktopStateAvailable",
        "desktopState",
        "loadStatus",
        "confidence",
        "mutability",
        "mayRepairRuntime",
        "provenance"
      ],
      "secretPolicy": "read-only provider metadata must redact token, secret, password, api_key, auth, cookie, and session-like values",
      "acceptanceRule": "Provider state is diagnostic evidence only. It cannot repair runtime state, cannot override ccstatus preflight refusal, and cannot override deterministic workflow verifiers."
    }
  },
  "dsRoutingSchema": {
    "routeType": "ds-advisory-routing-plan",
    "requiredFields": [
      "recommendation",
      "shouldRoute",
      "automaticDispatch",
      "trigger",
      "role",
      "runnerType",
      "model",
      "reason",
      "nextCommandTemplate",
      "taskFileGuidance",
      "evidencePaths",
      "confidence",
      "provenance",
      "advisoryOnly",
      "mayOverrideValidator",
      "mayOverrideVerifier",
      "canEditBusinessFiles",
      "canRunShellTests",
      "canDispatchWorkerRuns",
      "canAcceptWorkflowResults"
    ],
    "recommendationValues": [
      "recommended",
      "optional",
      "not_recommended"
    ],
    "automaticDispatchRule": "ccstatus may recommend a DS route, but must keep automaticDispatch=false. A main thread or explicit child-thread report-only TaskFile must opt in before any DS model call.",
    "acceptanceRule": "DS routing plans and DS reports are advisory friction reducers. They cannot override validate_delegate_task, ccstatus preflight refusal, run/workflow verifiers, review gates, or final acceptance."
  },
  "auditPackageSchema": {
    "artifactPattern": "audit_<RunId>.json",
    "markdownPattern": "audit_<RunId>.md",
    "workflowArtifactPattern": "audit_<WorkflowId>.json",
    "workflowMarkdownPattern": "audit_<WorkflowId>.md",
    "workflowVerifierArtifactPattern": "verifier_audit_<WorkflowId>.json",
    "workflowVerifierMarkdownPattern": "verifier_audit_<WorkflowId>.md",
    "command": "ccstatus audit -RunId <run-id> -ArtifactRoot <artifact-root> --json",
    "workflowCommand": "ccstatus audit -WorkflowId <workflow-id> -ArtifactRoot <artifact-root> --json",
    "workflowVerifierCommand": "verify_delegate_workflow -WorkflowId <workflow-id> -ArtifactRoot <artifact-root>",
    "requiredFields": [
      "auditType",
      "runId",
      "workflowId",
      "workerClaim",
      "reportValid",
      "changedFilesInScope",
      "testsDeclared",
      "testsObserved",
      "verifierPassed",
      "missingGates",
      "canEnterReview",
      "acceptanceAllowed",
      "failureLayer",
      "executionLayerFailure",
      "mainThreadAction",
      "dsRouting",
      "evidencePaths",
      "mayOverrideVerifier"
    ],
    "workflowVerifierRequiredFields": [
      "auditType",
      "workflowId",
      "verifierPassed",
      "acceptanceAllowed",
      "workflowFinalAcceptance",
      "gateResults",
      "failedGate",
      "missingGates",
      "verifiedRuns",
      "mainThreadAction",
      "evidencePaths",
      "mayOverrideVerifier"
    ],
    "acceptanceRule": "Audit packages summarize evidence for the main thread. They cannot override deterministic run/workflow verifiers and must keep mayOverrideVerifier=false."
  },
  "workerRoles": [
    "planner",
    "implementer",
    "researcher",
    "reviewer",
    "final-verifier"
  ],
  "reportStatusValues": [
    "DONE",
    "DONE_WITH_CONCERNS",
    "NEEDS_CONTEXT",
    "BLOCKED",
    "FAIL"
  ],
  "reportHeadings": [
    "Status",
    "Role",
    "Summary",
    "Changed Files",
    "Verification",
    "Findings",
    "Final Result",
    "Risks Or Follow-ups"
  ],
  "triggerPatterns": [
    "child[- ]?agent",
    "sub[- ]?agent",
    "child[- ]?thread",
    "sub[- ]?thread",
    "delegat(?:e|ion|ing)",
    "worker[- ]?execution",
    "子代理|子线程|多代理|委派|派工|执行层"
  ],
  "spawnToolNames": [
    "spawn_agent",
    "task",
    "subagent",
    "agent",
    "worker"
  ],
  "delegateEntrypointPattern": "delegate_to_claude(?:\\.(?:ps1|sh|cmd|bat))?",
  "delegateEntrypointPatterns": [
    "delegate_to_claude(?:\\.(?:ps1|sh|cmd|bat))?",
    "delegate_to_(?:openai(?:_compatible)?(?:_report(?:_only)?)?)(?:\\.(?:ps1|sh|cmd|bat))?"
  ],
  "requiredDelegateArgs": [
    "-TaskFile",
    "-WorkflowId",
    "-TaskId",
    "-Role",
    "-SessionKey"
  ],
  "reviewerRequiredArgs": [

    ],
    "forbiddenClaudeArgs": [
      "--effort"
    ]
  },
  "sessionModes": [
    "PrimaryReuse",
    "PrimaryAnchor",
    "ParallelPool"
  ],
  "reviewKinds": [
    "spec",
